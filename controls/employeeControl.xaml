<UserControl x:Class="finalExam_diplom_.controls.employeeControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:finalExam_diplom_.controls"
             xmlns:forms="clr-namespace:finalExam_diplom_.forms"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" Loaded="UserControl_Loaded">

    <UserControl.Resources>
        <Style TargetType="Button">
            <Style.Setters>
                <Setter Property="Button.Background" Value="#dfd3c3"/>
                <Setter Property="Button.Width" Value="120"/>
            </Style.Setters>
        </Style>
        <Style TargetType="DataGrid">
            <Style.Setters>
                <Setter Property="DataGrid.Background" Value="White"/>
            </Style.Setters>
        </Style>
    </UserControl.Resources>
    
    <Grid Background="white">
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="60"/>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.Column="0">
            <Label x:Name="searchLabel" Content="Поиск" FontFamily="Century Gothic" FontSize="16" VerticalContentAlignment="Center" HorizontalContentAlignment="Right"/>
        </Border>
        
        <Border Grid.Row="0" Grid.Column="1">
            <TextBox x:Name="employeeTextBox" 
                     FontFamily="Century Gothic" FontSize="16" 
                     Height="25" Margin="10" BorderBrush="Gray" 
                     TextChanged="employeeTextBox_TextChanged"/>
        </Border>

        <Border Grid.Row="1" Grid.ColumnSpan="3">
            <DataGrid x:Name="employeeDataGrid" 
                      Background="white" FontFamily="Century Gothic" 
                      FontSize="14" SelectionMode="Single" 
                      RowBackground="White" IsTabStop="True" IsHitTestVisible="True"
                      SelectionUnit="FullRow" AutoGenerateColumns="False" CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="#" Binding="{Binding id}" Width="Auto" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Табельный номер" Binding="{Binding employee_number}" Width="Auto" IsReadOnly="True"/>
                    <DataGridTextColumn Header="ФИО" Binding="{Binding fio}" Width="*" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Возраст" Binding="{Binding age}" Width="Auto" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Должность" Binding="{Binding position}" Width="Auto" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Опыт работы" Binding="{Binding experience}" Width="Auto" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Номер телефона" Binding="{Binding phone_number}" Width="Auto" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Статус" Binding="{Binding status}" Width="Auto" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Трудоустроен?" Binding="{Binding is_actual}" Width="Auto" IsReadOnly="True" Visibility="Hidden"/>

                    <DataGridTemplateColumn>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button x:Name="openApplication" Content="Открыть" Tag="{Binding openApp}"  ToolTip="Открыть заявку" Click="openApplication_Click"/>
                                    <Button x:Name="setTask" Content="Назначить задачу" Tag="{Binding setTask}"  ToolTip="Назначить задачу для этого сотрудника" IsEnabled="true" Click="setTask_Click"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
