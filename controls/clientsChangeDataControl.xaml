<UserControl x:Class="finalExam_diplom_.controls.clientsChangeDataControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:finalExam_diplom_.controls"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="600">
    
    <UserControl.Resources>
        <Style TargetType="Button">
            <Style.Setters>
                <Setter Property="Background" Value="#dfd3c3"/>
                <Setter Property="Width" Value="250"/>
                <Setter Property="Height" Value="40"/>
                <Setter Property="FontFamily" Value="Century Gothic"/>
                <Setter Property="FontSize" Value="16"/>
            </Style.Setters>
        </Style>
        <Style TargetType="TextBox">
            <Style.Setters>
                <Setter Property="Width" Value="250"/>
                <Setter Property="Height" Value="35"/>
                <Setter Property="FontFamily" Value="Century Gothic"/>
                <Setter Property="FontSize" Value="18"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style.Setters>
        </Style>
        <Style TargetType="ComboBox">
            <Style.Setters>
                <Setter Property="Width" Value="250"/>
                <Setter Property="Height" Value="35"/>
                <Setter Property="FontFamily" Value="Century Gothic"/>
                <Setter Property="FontSize" Value="18"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style.Setters>
        </Style>
        <Style TargetType="Label">
            <Style.Setters>
                <Setter Property="Width" Value="Auto"/>
                <Setter Property="Height" Value="30"/>
                <Setter Property="FontFamily" Value="Century Gothic"/>
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="Margin" Value="30,0,0,0"/>
                <Setter Property="Padding" Value="0,10,0,0"/>
                <Setter Property="HorizontalAlignment" Value="Left"/>
            </Style.Setters>
        </Style>
        <Style TargetType="DatePicker">
            <Style.Setters>
                <Setter Property="Width" Value="250"/>
                <Setter Property="Height" Value="35"/>
                <Setter Property="FontFamily" Value="Century Gothic"/>
                <Setter Property="FontSize" Value="18"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="SelectedDateFormat" Value="Long"/>
            </Style.Setters>
        </Style>
    </UserControl.Resources>

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="270"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>


        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="2" Grid.Column="0">
            <Button x:Name="addTaskButton" Content="Назначить"/>
        </Border>

        <Border Grid.Row="2" Grid.Column="1">
            <Button x:Name="closeFormButton" Content="Закрыть" Click="closeFormButton_Click"/>
        </Border>

        <Border Grid.Row="0" Grid.Column="0">
            <StackPanel Orientation="Vertical">
                <Label x:Name="clientTLabel" Content="ФИО клиента"/>
                <TextBox x:Name="clientTextBox" IsEnabled="false"/>
                
                <Label x:Name="addressLabel" Content="Адрес" />
                <TextBox x:Name="addressTextBox" IsEnabled="false"/>

                <Label x:Name="statusLabel" Content="Статус заявки"/>
                <ComboBox x:Name="statusComboBox"/>

                <Label x:Name="createdTimeLabel" Content="Время создания заявки"/>
                <DatePicker x:Name="createdTimeDatePicker" IsEnabled="false"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="0" Grid.Column="1">
            <StackPanel Orientation="Vertical">
                <Label x:Name="priorityLabel" Content="Приоритет заявки"/>
                <ComboBox x:Name="priorityComboBox"/>

                <Label x:Name="masterLabel" Content="Мастер"/>
                <ComboBox x:Name="masterComboBox"/>

                <Label x:Name="visitTimeLabel" Content="Время визита"/>
                <DatePicker x:Name="visitTimeDatePicker"/>

                <Label x:Name="closedTimeLabel" Content="Время закрытия заявки"/>
                <DatePicker x:Name="closedTimeDatePicker"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Grid.ColumnSpan="2">
            <StackPanel>
                <Label x:Name="managerLabel" Content="Ответственный диспетчер"/>
                <ComboBox x:Name="managerComboBox" Width="550"/>
                
                <Label x:Name="descriptionLabel" Content="Описание"/>
                <TextBox x:Name="descriptionTextBox" Width="550" Height="150" IsEnabled="false"/>

                <Label x:Name="masterCommentLabel" Content="Комментарий мастера" Visibility="Hidden"/>
                <TextBox x:Name="masterCommentTextBox" Width="550" Height="150" Visibility="Hidden"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
