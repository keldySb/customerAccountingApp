<UserControl x:Class="finalExam_diplom_.controls.mainControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:finalExam_diplom_.controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="1000" Loaded="UserControl_Loaded">
    <Grid x:Name="mainUCGrid" Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0">
            <TextBox x:Name="mainTextBox" Text="Поиск" 
                     FontFamily="Century Gothic" FontSize="16" BorderBrush="Gray" 
                     Height="25" Margin="10" 
                     GotFocus="mainTextBox_GotFocus" LostFocus="mainTextBox_LostFocus"/>
        </Border>


        <Border Grid.Column="1" Grid.ColumnSpan="2">
            <ComboBox x:Name="mainComboBox" Text="Выберите статус заявки" FontFamily="Century Gothic" FontSize="16" BorderBrush="white" Height="25" Margin="10"/>
        </Border>

        <Border Grid.Row="1" Grid.ColumnSpan="2">
            <DataGrid x:Name="mainDataGrid" 
                      Background="white" FontFamily="Century Gothic" 
                      FontSize="14" SelectionMode="Single" 
                      RowBackground="White" IsTabStop="True" IsHitTestVisible="True"
                      SelectionUnit="FullRow">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="#" Binding="{Binding [# заявки]}" Width="50" IsReadOnly="True"/>
                    <DataGridTextColumn Header="ФИО" Binding="{Binding [ФИО клиента]}" Width="100" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Адрес" Binding="{Binding Адрес}" Width="100" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Описание" Binding="{Binding Описание}" Width="*" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Статус" Binding="{Binding Статус}" Width="80" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Приоритет" Binding="{Binding Приоритет}" Width="80" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Источник" Binding="{Binding Источник}" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Ответственный менеджер" Binding="{Binding Менеджер}" Width="80" IsReadOnly="True" Visibility="Hidden"/>
                    <DataGridTextColumn Header="Ответственный мастер" Binding="{Binding Мастер}" Width="150" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Дата создания" Binding="{Binding [Дата создания]}" Width="120" IsReadOnly="True"/>
                    <DataGridTextColumn Header="Дата визита" Binding="{Binding [Дата визита]}" Width="100" IsReadOnly="True" Visibility="Hidden"/>
                    <DataGridTextColumn Header="Дата закрытия заявки" Binding="{Binding [Дата закрытия заявки]}" Width="100" IsReadOnly="True" Visibility="Hidden"/>
                    <DataGridTextColumn Header="Комментарий" Binding="{Binding [Комментарий мастера]}" Width="150" IsReadOnly="True" Visibility="Hidden"/>

                    <DataGridTemplateColumn>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button x:Name="openApplication" Content="Открыть" Width="120" Margin="5" ToolTip="Открыть заявку"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
