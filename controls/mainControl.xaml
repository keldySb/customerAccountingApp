<UserControl x:Class="finalExam_diplom_.controls.mainControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:finalExam_diplom_.controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid x:Name="mainUCGrid" Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0">
            <TextBox x:Name="mainTextBox" Text="Поиск" 
                     FontFamily="Century Gothic" FontSize="16" BorderBrush="Gray" 
                     Height="25" Margin="10" 
                     GotFocus="mainTextBox_GotFocus" LostFocus="mainTextBox_LostFocus"/>
        </Border>


        <Border Grid.Column="1" Grid.ColumnSpan="2">
            <ComboBox x:Name="mainComboBox" Text="Выберите статус заявки" FontFamily="Century Gothic" FontSize="16" BorderBrush="white" Height="25" Margin="10"/>
        </Border>

        <Border Grid.Row="1" Grid.ColumnSpan="2">
            <DataGrid x:Name="mainDataGrid" Background="white"/>
        </Border>
    </Grid>
</UserControl>
