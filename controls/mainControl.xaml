<UserControl x:Class="finalExam_diplom_.controls.mainControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:finalExam_diplom_.controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="1000" Loaded="UserControl_Loaded">
    <UserControl.Resources>
        <Style TargetType="Button">
            <Style.Setters>
                <Setter Property="Button.Background" Value="#dfd3c3"/>
                <Setter Property="Button.Width" Value="120"/>
            </Style.Setters>
            <Style.Triggers>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Button.Background" Value="Red"></Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGrid">
            <Style.Setters>
                <Setter Property="DataGrid.Background" Value="White"/>
            </Style.Setters>
            <Style.Triggers>
                <Trigger Property="DataGrid.Background" Value="Gray"/>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid x:Name="mainUCGrid" Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" x:Name="searchBorder">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Label x:Name="mainSearchLabel" Content="Поиск" FontFamily="Century Gothic" FontSize="16" 
                       VerticalContentAlignment="Center" HorizontalContentAlignment="Right" Grid.Column="0"/>
                <TextBox x:Name="mainTextBox" 
                     FontFamily="Century Gothic" FontSize="16" BorderBrush="Gray" 
                     Height="25" Margin="10" TextChanged="mainTextBox_TextChanged" Grid.Column="1"/>
            </Grid>
        </Border>

        <Border Grid.Column="1" x:Name="statusBorder">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>

                </Grid.ColumnDefinitions>
            
            <Label x:Name="mainComboBoxLabel" 
                   Content="Выбор статуса" FontFamily="Century Gothic" FontSize="16" 
                   HorizontalContentAlignment="Center" VerticalContentAlignment="Center" 
                   Width="150" Grid.Column="0"/>
            <ComboBox x:Name="mainComboBox" 
                      FontFamily="Century Gothic" FontSize="16" 
                      BorderBrush="white" Height="25" 
                      DisplayMemberPath="name" SelectedValuePath="id" SelectedIndex="0" SelectionChanged="mainComboBox_SelectionChanged" Grid.Column="1"/>
            </Grid>
        </Border>

        <Border Grid.Row="1" Grid.ColumnSpan="4">
            <DataGrid x:Name="mainDataGrid" 
                      Background="white" FontFamily="Century Gothic" 
                      FontSize="14" SelectionMode="Single" 
                      RowBackground="White" IsTabStop="True" IsHitTestVisible="True"
                      SelectionUnit="FullRow" AutoGenerateColumns="False" MouseDoubleClick="mainDataGrid_MouseDoubleClick" CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn x:Name="id" Header="#" Binding="{Binding id}" Width="Auto" IsReadOnly="True"/>
                    <DataGridTextColumn x:Name="fio" Header="ФИО" Binding="{Binding fio}" Width="Auto" IsReadOnly="True"/>
                    <DataGridTextColumn x:Name="address" Header="Адрес" Binding="{Binding address}" Width="Auto" IsReadOnly="True"/>
                    <DataGridTextColumn x:Name="description" Header="Описание" Binding="{Binding description}" Width="*" IsReadOnly="True"/>
                    <DataGridTextColumn x:Name="status_id" Header="Идентификатор статуса" Binding="{Binding status_id}" Width="Auto" IsReadOnly="True" Visibility="Collapsed"/>
                    <DataGridTextColumn x:Name="status" Header="Статус" Binding="{Binding status}" Width="Auto" IsReadOnly="True"/>
                    <DataGridTextColumn x:Name="priority_id" Header="Идентификатор приоритета" Binding="{Binding priority_id}" Width="Auto" IsReadOnly="True" Visibility="Collapsed"/>
                    <DataGridTextColumn x:Name="priority" Header="Приоритет" Binding="{Binding priority}" Width="Auto" IsReadOnly="True"/>
                    <DataGridTextColumn x:Name="manager_id" Header="Идентификатор менеджерa" Binding="{Binding manager_id}" Width="Auto" IsReadOnly="True" Visibility="Collapsed"/>
                    <DataGridTextColumn x:Name="manager" Header="Ответственный менеджер" Binding="{Binding manager}" Width="Auto" IsReadOnly="True" Visibility="Collapsed"/>
                    <DataGridTextColumn x:Name="master_id" Header="Идентификатор мастерa" Binding="{Binding master_id}" Width="Auto" IsReadOnly="True" Visibility="Collapsed"/>
                    <DataGridTextColumn x:Name="master" Header="Ответственный мастер" Binding="{Binding master}" Width="Auto" IsReadOnly="True" Visibility="Collapsed"/>
                    <DataGridTextColumn x:Name="created_time" Header="Дата создания" Binding="{Binding created_time}" Width="Auto" IsReadOnly="True"/>
                    <DataGridTextColumn x:Name="visit_time" Header="Дата визита" Binding="{Binding visit_time}" Width="Auto" IsReadOnly="True" Visibility="Collapsed"/>
                    <DataGridTextColumn x:Name="closed_time" Header="Дата закрытия заявки" Binding="{Binding closed_time}" Width="Auto" IsReadOnly="True" Visibility="Collapsed"/>
                    <DataGridTextColumn x:Name="master_comment" Header="Комментарий" Binding="{Binding master_comment}" Width="Auto" IsReadOnly="True" Visibility="Collapsed"/>

                    <DataGridTemplateColumn Width="Auto">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button x:Name="openApplication" Content="Открыть" Width="120" ToolTip="Открыть заявку"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn x:Name="setTaskFoeEmpColumn"  Width="Auto" Visibility="Collapsed">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button x:Name="setTaskForEmpButton" Content="Назначить" Width="150" ToolTip="Назначить задачу"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
