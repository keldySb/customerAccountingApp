<UserControl x:Class="finalExam_diplom_.controls.employeeOpenDataControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:finalExam_diplom_.controls"
             mc:Ignorable="d" 
             d:DesignHeight="350" d:DesignWidth="600">
    
    <UserControl.Resources>
        <Style TargetType="Button">
            <Style.Setters>
                <Setter Property="Button.Background" Value="#dfd3c3"/>
                <Setter Property="Button.Width" Value="250"/>
                <Setter Property="Button.Height" Value="40"/>
                <Setter Property="Button.FontFamily" Value="Century Gothic"/>
                <Setter Property="Button.FontSize" Value="16"/>
            </Style.Setters>
        </Style>
        <Style TargetType="TextBox">
            <Style.Setters>
                <Setter Property="TextBox.Width" Value="250"/>
                <Setter Property="TextBox.Height" Value="35"/>
                <Setter Property="TextBox.FontFamily" Value="Century Gothic"/>
                <Setter Property="TextBox.FontSize" Value="18"/>
                <Setter Property="TextBox.VerticalContentAlignment" Value="Center"/>
            </Style.Setters>
        </Style>
        <Style TargetType="Label">
            <Style.Setters>
                <Setter Property="Label.Width" Value="Auto"/>
                <Setter Property="Label.Height" Value="30"/>
                <Setter Property="Label.FontFamily" Value="Century Gothic"/>
                <Setter Property="Label.FontSize" Value="16"/>
                <Setter Property="Label.Margin" Value="30,0,0,0"/>
                <Setter Property="Label.Padding" Value="0,10,0,0"/>
                <Setter Property="Label.HorizontalAlignment" Value="Left"/>
            </Style.Setters>
        </Style>
    </UserControl.Resources>

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="280"/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="1" Grid.Column="0">
            <Button x:Name="addTaskButton" Content="Назначить"/>
        </Border>

        <Border Grid.Row="1" Grid.Column="1">
            <Button x:Name="closeFormButton" Content="Закрыть" Click="closeFormButton_Click"/>
        </Border>

        <Border Grid.Row="0" Grid.Column="0">
            <StackPanel Orientation="Vertical">
                <Label x:Name="employeeLabel" Content="Табельный номер"/>
                <TextBox x:Name="employeeNumberTextBox"/>
                
                <Label x:Name="fioLabel" Content="ФИО"/>
                <TextBox x:Name="fioTextBox"/>

                <Label x:Name="ageLabel" Content="Возраст"/>
                <TextBox x:Name="ageTextBox"/>

                <Label x:Name="positionLabel" Content="Должность"/>
                <TextBox x:Name="positionTextBox"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="0" Grid.Column="1">
            <StackPanel Orientation="Vertical">
                <Label x:Name="experienceLabel" Content="Опыт работы"/>
                <TextBox x:Name="experienceTextBox"/>

                <Label x:Name="phoneNumberLabel" Content="Номер телефона"/>
                <TextBox x:Name="phoneNumberTextBox"/>

                <Label x:Name="statusLabel" Content="Статус"/>
                <TextBox x:Name="statusTextBox"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
