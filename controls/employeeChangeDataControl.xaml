<UserControl x:Class="finalExam_diplom_.controls.employeeChangeDataControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:finalExam_diplom_.controls"
             mc:Ignorable="d" 
             d:DesignHeight="500" d:DesignWidth="600">
    
    <UserControl.Resources>
        <Style TargetType="Button">
            <Style.Setters>
                <Setter Property="Button.Background" Value="#dfd3c3"/>
                <Setter Property="Button.Width" Value="250"/>
                <Setter Property="Button.Height" Value="40"/>
                <Setter Property="Button.FontFamily" Value="Century Gothic"/>
                <Setter Property="Button.FontSize" Value="16"/>
            </Style.Setters>
        </Style>
        <Style TargetType="TextBox">
            <Style.Setters>
                    <Setter Property="TextBox.Width" Value="250"/>
                    <Setter Property="TextBox.Height" Value="40"/>
                    <Setter Property="TextBox.FontFamily" Value="Century Gothic"/>
                    <Setter Property="TextBox.FontSize" Value="16"/>
                    <Setter Property="TextBox.Margin" Value="25"/>
                </Style.Setters>
        </Style>
    </UserControl.Resources>

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="400"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="1" Grid.Column="0">
            <Button x:Name="addTaskButton" Content="Назначить"/>
        </Border>

        <Border Grid.Row="1" Grid.Column="1">
            <Button x:Name="closeFormButton" Content="Закрыть"/>
        </Border>

        <Border Grid.Row="0" Grid.Column="0" Margin="0,15,0,0">
            <StackPanel Orientation="Vertical">
                <TextBox x:Name="employeeNumberTextBox"/>
                <TextBox x:Name="fioTextBox"/>
                <TextBox x:Name="ageTextBox"/>
                <TextBox x:Name="positionTextBox"/>
            </StackPanel>
        </Border>
        <Border Grid.Row="0" Grid.Column="1" Margin="0,15,0,0">
            <StackPanel Orientation="Vertical">
                <TextBox x:Name="experienceTextBox"/>
                <TextBox x:Name="phoneNumberTextBox"/>
                <TextBox x:Name="statusTextBox"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
