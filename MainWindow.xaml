<Window x:Class="finalExam_diplom_.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:finalExam_diplom_"
        xmlns:controls="clr-namespace:finalExam_diplom_.controls"
        mc:Ignorable="d" Height="900" Width="1200" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="Button">
            <Style.Setters>
                <Setter Property="Background" Value="#dfd3c3"/>
                <Setter Property="Height" Value="40"/>
                <Setter Property="FontFamily" Value="Century Gothic"/>
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="Margin" Value="1"/>
            </Style.Setters>

            <Style.Triggers>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="Red"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    
    
    <Grid x:Name="mainGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="#c7b198">
            <TextBlock x:Name="headerTextBox" Text="Заявки клиентов" FontFamily="Century Gothic" FontSize="20" Foreground="Black" VerticalAlignment="Center" Margin="20"/>
        </Border>

        <Border Grid.Row="1" Grid.Column="0">
            <StackPanel Background="#f0ece2">
                <Button x:Name="mainButton"  Content="Заявки клиентов" Click="mainButton_Click"/>
                <Button x:Name="employeeButton" Content="Сотрудники" Click="employeeButton_Click"/>
                <Button x:Name="reportButton"  Content="Отчеты" Click="reportButton_Click"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Grid.Column="1" Margin="5">
            <ContentControl x:Name="useControl"/>
        </Border>
    </Grid>
</Window>
